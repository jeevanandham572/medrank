rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Colleges collection
    match /colleges/{collegeId} {
      // Anyone can read colleges
      allow read: if true;
      
      // For MVP/testing: Allow anyone to create colleges (used by our seed button)
      // In production, you would restrict this to admins
      allow create: if true;
      allow update, delete: if false; // Only allow creation, no deleting or updating from client
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      
      // Anyone can create a review
      // The review must contain the required fields (basic validation)
      allow create: if true 
                   && request.resource.data.keys().hasAll(['collegeId', 'overallRating', 'comment', 'teaching', 'infrastructure', 'patientLoad', 'hostel']);
                   
      allow update, delete: if false; // Reviews cannot be edited or deleted by users
    }
  }
}
